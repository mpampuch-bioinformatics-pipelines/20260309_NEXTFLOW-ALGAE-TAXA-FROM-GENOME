nextflow_process {

    name "Test Process BARRNAP"
    script "../main.nf"
    process "BARRNAP"
    tag "modules"
    tag "modules_nfcore"
    tag "barrnap"

    // =========================================================================
    // REAL TESTS
    // =========================================================================

    // POTENTIAL TODO: Find a more appropriate test data set for this module to increase the testing speed. Right now KAUST067 is a large genome and takes a long time to test.

    test("barrnap - euk") {
        tag "slow"
        tag "barrnap_euk"
        options "-dump-hashes"

        when {
            process {
                """
                input[0] = [
                    [ id:'KAUST067' ], // meta map
                    file('/ibex/scratch/projects/c2303/20260309_NEXTFLOW-ALGAE-TAXA-FROM-GENOME/DATA/KAUST067_purged.fa', checkIfExists: true),
                    'euk'
                ]
                """
            }
        }

        then {
            DebugUtils.printTree(process.out)

            assert process.success

            assert process.out.gff.size() == 1
            assert process.out.gff[0][0].id == 'KAUST067'
            assert file(process.out.gff[0][1]).name.endsWith('.gff')
            assert file(process.out.gff[0][1]).name.contains('euk')

            assert process.out.versions.size() == 1

            assert snapshot(process.out).match()
        }
    }

