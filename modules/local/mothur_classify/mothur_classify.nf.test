nextflow_process {

    name "Test Process MOTHUR_CLASSIFY"
    script "modules/local/mothur_classify/mothur_classify.nf"
    process "MOTHUR_CLASSIFY"
    config 'conf/databases.config'
    tag "modules"
    tag "modules_local"
    tag "mothur_classify"

    // =========================================================================
    // REAL TESTS
    // =========================================================================

    test("KAUST067 | ITS1 | mothur classify | EUKARYOME_ITS") {
        config "modules/local/mothur_classify/mothur_classify.test.config"
        options "-dump-hashes"
        tag 'slow'
        tag 'from_ITSx'
        when {
            process {
                """
                input[0] = [
                    [ id: 'KAUST067', seq_type: 'ITS1', database: 'EUKARYOME_ITS' ],
                    file('${projectDir}/modules/local/mothur_classify/TESTDATA/KAUST067_purged.ITS1.fasta', checkIfExists: true),
                    'ITS1',
                    file(params.eukaryome_its_fasta, checkIfExists: true),
                    file(params.eukaryome_its_taxonomy, checkIfExists: true)
                ]
                """
            }
        }
        then {
            DebugUtils.printTree(process.out)
            assert process.success
            assert process.out.taxonomy.size() == 1
            assert process.out.taxonomy[0][0].id == 'KAUST067'
            assert file(process.out.taxonomy[0][1]).name == 'KAUST067.ITS1.DB_EUKARYOME_ITS.taxonomy'
            assert file(process.out.taxonomy[0][1]).size() > 0
            assert process.out.summary.size() == 1
            assert process.out.summary[0][0].id == 'KAUST067'
            assert file(process.out.summary[0][1]).name == 'KAUST067.ITS1.DB_EUKARYOME_ITS.summary'
            assert file(process.out.summary[0][1]).size() > 0
            assert process.out.versions.size() == 1
            assert path(process.out.versions[0]).readLines().any { line -> line.contains('mothur') }
            assert snapshot(process.out).match()
        }
    }

