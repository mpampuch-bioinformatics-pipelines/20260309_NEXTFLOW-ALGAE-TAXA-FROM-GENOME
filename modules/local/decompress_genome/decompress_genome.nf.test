    }
    // =========================================================================
    // STUB TESTS
    // =========================================================================

    test("stub | .fa.gz - stubs to .fa") {
        tag "stub"
        tag "fast"
        options "-stub-run -dump-hashes"

        when {
            process {
                """
                input[0] = [
                    [ id: 'test_fa' ],
                    file("${projectDir}/modules/local/decompress_genome/TESTDATA/GCA_009858895.3_ASM985889v3_genomic.200409.fa.gz")
                ]
                """
            }
        }

        then {
            DebugUtils.printTree(process.out)
            assert process.success

            // Output genome file exists with correct extension
            // stub block uses `touch`, so the file is intentionally empty (size == 0)
            assert process.out.genome.size() == 1
            assert file(process.out.genome[0][1]).name.endsWith('.fa')
            assert file(process.out.genome[0][1]).size() == 0

            // Metadata passthrough
            assert process.out.genome[0][0].id == 'test_fa'

            // versions.yml is emitted
            assert process.out.versions.size() == 1

            assert snapshot(process.out).match()
        }

    }

    test("stub | .fasta.gz - stubs to .fasta") {
        tag "stub"
        tag "fast"
        options "-stub-run -dump-hashes"

        when {
