nextflow_process {

    name "Test Process DECOMPRESS_GENOME"
    script "modules/local/decompress_genome/decompress_genome.nf"
    process "DECOMPRESS_GENOME"

    test(".fa.gz - decompresses to .fa") {
        tag "fast"
        options "-dump-hashes"

        when {
            process {
                """
                input[0] = [
                    [ id: 'test_fa' ],
                    file("${projectDir}/modules/local/decompress_genome/TESTDATA/GCA_009858895.3_ASM985889v3_genomic.200409.fa.gz")
                ]
                """
            }
        }

        then {
            DebugUtils.printTree(process.out)
            
            assert process.success

            // Output genome file exists and has expected extension
            assert process.out.genome.size() == 1
            assert file(process.out.genome[0][1]).name.endsWith('.fa')
            assert file(process.out.genome[0][1]).size() > 0

            // Metadata passthrough
            assert process.out.genome[0][0].id == 'test_fa'

            // versions.yml is emitted
            assert process.out.versions.size() == 1

            assert snapshot(process.out).match()
        }

    }

    test(".fasta.gz - decompresses to .fasta") {
        tag "fast"
        options "-dump-hashes"

        when {
            process {
                """
                input[0] = [
                    [ id: 'test_fasta' ],
