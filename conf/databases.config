/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Database Configuration Template
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Example configuration for taxonomy classification databases.
    Copy this file and update paths to match your database locations.
----------------------------------------------------------------------------------------
*/

params {
    // Enable/disable mothur classification
    run_mothur_classification = true
    
    // Mothur classification cutoff (default: 80)
    mothur_cutoff = 80

    // EUKARYOME Database v2.0
    // Small Subunit (SSU/18S rRNA) database
    eukaryome_ssu_fasta     = '/path/to/EUKARYOME/mothur/mothur_EUK_SSU_v2.0.fasta'
    eukaryome_ssu_taxonomy  = '/path/to/EUKARYOME/mothur/mothur_EUK_SSU_v2.0.tax'
    
    // Large Subunit (LSU/28S rRNA) database
    eukaryome_lsu_fasta     = '/path/to/EUKARYOME/mothur/mothur_EUK_LSU_v2.0.fasta'
    eukaryome_lsu_taxonomy  = '/path/to/EUKARYOME/mothur/mothur_EUK_LSU_v2.0.tax'
    
    // Internal Transcribed Spacer (ITS/5.8S) database
    eukaryome_its_fasta     = '/path/to/EUKARYOME/mothur/mothur_EUK_ITS_v2.0.fasta'
    eukaryome_its_taxonomy  = '/path/to/EUKARYOME/mothur/mothur_EUK_ITS_v2.0.tax'
    
    // Long-read full-length database (covers SSU-ITS-LSU)
    eukaryome_longread_fasta    = '/path/to/EUKARYOME/mothur/mothur_EUK_longread_v2.0.fasta'
    eukaryome_longread_taxonomy = '/path/to/EUKARYOME/mothur/mothur_EUK_longread_v2.0.tax'

    // PR2 Database v5.1.1
    // Protist Ribosomal Reference database (alternative SSU database)
    pr2_ssu_fasta     = '/path/to/PR2/pr2_version_5.1.1_SSU_mothur.fasta'
    pr2_ssu_taxonomy  = '/path/to/PR2/pr2_version_5.1.1_SSU_mothur.tax'

    // SILVA Database (for bacterial/archaeal 16S/23S classification)
    silva_fasta     = '/path/to/SILVA/silva.fasta'
    silva_taxonomy  = '/path/to/SILVA/silva.tax'
}
