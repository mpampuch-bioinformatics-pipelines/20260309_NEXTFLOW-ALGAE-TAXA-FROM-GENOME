/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // -----------------------------------------------------------------------
    // BARRNAP — results/{sample}/barrnap/
    //   outputs: {sample}.bac.rRNA.gff  (barrnap emits {prefix}_{db}.gff)
    //            {sample}.arc.rRNA.gff
    //            {sample}.euk.rRNA.gff
    //            {sample}.mito.rRNA.gff
    //
    // The barrnap module names the output  ${prefix}_${db}.gff, so the file
    // will be e.g. KAUST067_bac.gff – we rename via saveAs to match the
    // canonical {sample}.{db}.rRNA.gff convention.
    // -----------------------------------------------------------------------
    withName: 'BARRNAP_BAC' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/barrnap" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml')) return null
                // KAUST067_bac.gff  →  KAUST067.bac.rRNA.gff
                filename.replaceAll(/_bac\.gff$/, '.bac.rRNA.gff')
            }
        ]
    }

    withName: 'BARRNAP_ARC' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/barrnap" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml')) return null
                filename.replaceAll(/_arc\.gff$/, '.arc.rRNA.gff')
            }
        ]
    }

    withName: 'BARRNAP_EUK' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/barrnap" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml')) return null
                filename.replaceAll(/_euk\.gff$/, '.euk.rRNA.gff')
            }
        ]
    }

    withName: 'BARRNAP_MITO' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/barrnap" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml')) return null
                filename.replaceAll(/_mito\.gff$/, '.mito.rRNA.gff')
            }
        ]
    }

    // -----------------------------------------------------------------------
    // COMBINE_GFF — results/{sample}/combined_gff/
    //   output:  {sample}.all.rRNA.gff   (already named correctly by the module)
    // -----------------------------------------------------------------------
    withName: 'COMBINE_GFF' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/combined_gff" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // -----------------------------------------------------------------------
    // EXTRACT_BED — results/{sample}/bed_coordinates/
    //   outputs: {sample}.5s.bed, {sample}.5_8s.bed, {sample}.12s.bed, etc.
    //            (already named correctly by the module)
    // -----------------------------------------------------------------------
    withName: 'EXTRACT_BED' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/bed_coordinates" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // -----------------------------------------------------------------------
    // BEDTOOLS_GETFASTA — results/{sample}/extracted_sequences/
    //   outputs: {sample}.5s.fa, {sample}.5_8s.fa, {sample}.18s.fa, etc.
    //   ext.prefix is set to meta.bed_stem (e.g. "KAUST067.18s") so the
    //   module emits  KAUST067.18s.fa  — no renaming needed.
    // -----------------------------------------------------------------------
    withName: 'BEDTOOLS_GETFASTA' {
        ext.prefix = { meta.bed_stem }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/extracted_sequences" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // -----------------------------------------------------------------------
    // CLEAN_FASTA_HEADERS — results/{sample}/extracted_sequences/
    //   Runs immediately after BEDTOOLS_GETFASTA; rewrites headers in-place.
    //   ext.prefix mirrors BEDTOOLS_GETFASTA (meta.bed_stem) so output names
    //   are identical: e.g. KAUST067.18s.fa (with clean headers).
    // -----------------------------------------------------------------------
    withName: 'CLEAN_FASTA_HEADERS' {
        ext.prefix = { meta.bed_stem }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/extracted_sequences" },
            mode: params.publish_dir_mode,
            // Overwrite the raw bedtools output with the cleaned version
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // -----------------------------------------------------------------------
    // ITSX — results/{sample}/itsx/
    //   outputs: {sample}.ITS1.fasta, {sample}.ITS2.fasta,
    //            {sample}.SSU.fasta,  {sample}.LSU.fasta,
    //            {sample}.summary.txt   (all named correctly by the module)
    // -----------------------------------------------------------------------
    withName: 'ITSX' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/itsx" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // -----------------------------------------------------------------------
    // MOTHUR_CLASSIFY — results/{sample}/classifications/
    //   outputs: {sample}.{seq_type}.DB_{database}.taxonomy
    //            {sample}.{seq_type}.DB_{database}.tax.summary
    //   The module already has a hardcoded publishDir; this withName block
    //   overrides it to keep all publishing config in one place.
    // -----------------------------------------------------------------------
    withName: 'MOTHUR_CLASSIFY' {
        // Blank FASTA inputs (e.g. no ITS detected by ITSx) cause mothur to exit 1.
        // Upstream filters remove empty FASTAs, but 'ignore' is kept as a safety net
        // so a single failed classification never aborts the whole pipeline.
        errorStrategy = 'ignore'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/classifications" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // -----------------------------------------------------------------------
    // MULTIQC — results/multiqc/
    // -----------------------------------------------------------------------
    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

}
